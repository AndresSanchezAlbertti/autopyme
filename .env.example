# ============================================================
# AutoPyme — Variables de entorno
# Copiar este archivo como .env y completar los valores
# NUNCA subir .env al repositorio
# ============================================================

# --- General ---
ENVIRONMENT=development
TIMEZONE=America/Argentina/Buenos_Aires

# --- PostgreSQL ---
POSTGRES_DB=autopyme
POSTGRES_USER=autopyme
POSTGRES_PASSWORD=cambia_esto_en_produccion

# --- Backend FastAPI ---
SECRET_KEY=genera_una_clave_secreta_con_openssl_rand_hex_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# URL de conexión (la usa SQLAlchemy)
DATABASE_URL=postgresql+asyncpg://autopyme:cambia_esto_en_produccion@db:5432/autopyme

# --- Frontend ---
NEXT_PUBLIC_API_URL=https://api.tudominio.com
NEXT_PUBLIC_APP_NAME=AutoPyme

# --- n8n ---
N8N_HOST=automation.tudominio.com
N8N_PROTOCOL=https
N8N_WEBHOOK_URL=https://automation.tudominio.com/
N8N_EDITOR_BASE_URL=https://automation.tudominio.com/
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=cambia_esto_en_produccion
N8N_ENCRYPTION_KEY=genera_una_clave_con_openssl_rand_hex_32
N8N_DB=n8n

# URL interna para que el backend llame a n8n
N8N_INTERNAL_URL=http://n8n:5678
N8N_API_KEY=

# --- WhatsApp Cloud API ---
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=token_secreto_para_verificacion_del_webhook

# --- Gmail / SMTP ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@tudominio.com

# --- Google Sheets (via n8n, pero referencia aquí) ---
GOOGLE_SHEETS_CREDENTIALS_PATH=

# --- Sentry (opcional) ---
SENTRY_DSN=

# --- CORS ---
ALLOWED_ORIGINS=https://tudominio.com,https://www.tudominio.com

# --- Dominio (para Nginx y Certbot) ---
DOMAIN=tudominio.com
API_SUBDOMAIN=api.tudominio.com
APP_SUBDOMAIN=app.tudominio.com
N8N_SUBDOMAIN=automation.tudominio.com
CERTBOT_EMAIL=tu@email.com
